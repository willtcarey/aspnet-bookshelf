@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="mx-auto flex max-w-3xl flex-col gap-6">
    <div class="space-y-2">
        <h1 class="text-3xl font-black tracking-tight text-error">Something went wrong</h1>
        <p class="text-base-content/75">An error occurred while processing your request.</p>
    </div>

    <div class="alert alert-error shadow-lg">
        <span>If the problem keeps happening, check the development logs and try the request again.</span>
    </div>

    @if (Model.ShowRequestId)
    {
        <div class="card bg-base-100 shadow-lg ring-1 ring-base-300/60">
            <div class="card-body">
                <h2 class="card-title">Request details</h2>
                <p>
                    <strong>Request ID:</strong>
                    <code class="rounded bg-base-200 px-2 py-1 text-sm">@Model.RequestId</code>
                </p>
            </div>
        </div>
    }

    <div class="card bg-base-100 shadow-lg ring-1 ring-base-300/60">
        <div class="card-body gap-3">
            <h2 class="card-title">Development mode</h2>
            <p class="text-sm text-base-content/75">
                Swapping to the <strong>Development</strong> environment will show more detailed information about the error.
                Avoid enabling that mode for deployed applications because it can expose sensitive information.
            </p>
        </div>
    </div>
</div>
