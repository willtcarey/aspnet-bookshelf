<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bookshelf</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav>
            <a class="brand" asp-area="" asp-controller="Home" asp-action="Index">Bookshelf</a>
            <ul>
                <li><a asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
                <li><a asp-area="" asp-controller="Books" asp-action="Index">Books</a></li>
                <li><a asp-area="" asp-controller="Authors" asp-action="Index">Authors</a></li>
                <li><a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
            </ul>
            <ul class="account-nav">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li><span class="user-email">@User.Identity.Name</span></li>
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="inline-form">
                            <button type="submit" class="link-button">Log Out</button>
                        </form>
                    </li>
                }
                else
                {
                    <li><a asp-controller="Account" asp-action="Login">Log In</a></li>
                    <li><a asp-controller="Account" asp-action="Register">Register</a></li>
                }
            </ul>
        </nav>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer>
        &copy; 2026 - Bookshelf - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
