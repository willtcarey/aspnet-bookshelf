@model IEnumerable<Bookshelf.Models.Book>

@{
    ViewData["Title"] = "Books";
    var canManage = User.Identity?.IsAuthenticated == true;
}

<div class="flex flex-col gap-6">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div class="space-y-2">
            <h1 class="text-3xl font-black tracking-tight">Books</h1>
            <p class="text-base-content/75">Browse the books in your library, then dive into details or manage entries when you’re signed in.</p>
        </div>

        @if (canManage)
        {
            <a class="btn btn-primary" asp-action="Create">Add a book</a>
        }
        else
        {
            <a class="btn btn-outline" asp-controller="Account" asp-action="Login">Log in to add books</a>
        }
    </div>

    @if (Model.Any())
    {
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
            @foreach (var book in Model)
            {
                <a asp-action="Details" asp-route-id="@book.Id" class="group flex flex-col gap-3">
                    <div class="overflow-hidden rounded-xl shadow-lg ring-1 ring-base-300/60 transition-all duration-200 group-hover:shadow-xl group-hover:ring-primary/40">
                        @if (!string.IsNullOrWhiteSpace(book.CoverImagePath))
                        {
                            <image-upload path="@book.CoverImagePath" width="320" height="480" alt="Cover for @book.Title" class="aspect-[2/3] w-full object-cover transition-transform duration-200 group-hover:scale-[1.03]" loading="lazy" />
                        }
                        else
                        {
                            <div class="flex aspect-[2/3] w-full items-center justify-center bg-base-200 px-4 text-center text-[0.625rem] font-semibold uppercase tracking-[0.2em] text-base-content/45 transition-colors duration-200 group-hover:bg-base-300">
                                No cover
                            </div>
                        }
                    </div>

                    <div class="flex flex-col gap-0.5 px-0.5">
                        <h2 class="line-clamp-2 text-sm font-bold leading-snug group-hover:text-primary">@book.Title</h2>
                        <p class="truncate text-xs text-base-content/70">@book.Author.Name</p>
                        @if (book.Year.HasValue)
                        {
                            <p class="text-xs text-base-content/50">@book.Year</p>
                        }
                    </div>
                </a>
            }
        </div>
    }
    else
    {
        <div class="hero rounded-3xl bg-base-100 py-16 shadow-xl ring-1 ring-base-300/60">
            <div class="hero-content text-center">
                <div class="max-w-md space-y-4">
                    <h2 class="text-2xl font-bold">No books yet</h2>
                    <p class="text-base-content/75">Start your shelf with the first title in your collection.</p>
                    @if (canManage)
                    {
                        <a class="btn btn-primary" asp-action="Create">Add your first book</a>
                    }
                </div>
            </div>
        </div>
    }
</div>
