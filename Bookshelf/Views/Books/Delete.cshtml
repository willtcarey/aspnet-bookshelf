@model Bookshelf.Models.Book

@{
    ViewData["Title"] = "Delete Book";
}

<div class="mx-auto flex max-w-3xl flex-col gap-6">
    <div class="space-y-2">
        <h1 class="text-3xl font-black tracking-tight text-error">Delete book</h1>
        <p class="text-base-content/75">This action removes the book from your library.</p>
    </div>

    <div class="alert alert-warning shadow-lg">
        <span>Are you sure you want to delete <strong>@Model.Title</strong> by @Model.Author.Name?</span>
    </div>

    <div class="card bg-base-100 shadow-xl ring-1 ring-base-300/60">
        <div class="card-body gap-6">
            <div class="grid gap-6 md:grid-cols-[8rem_minmax(0,1fr)]">
                <div>
                    @if (!string.IsNullOrWhiteSpace(Model.CoverImagePath))
                    {
                        <img src="@Model.CoverImagePath" alt="Cover for @Model.Title" class="h-48 w-32 rounded-xl object-cover shadow" />
                    }
                    else
                    {
                        <div class="flex h-48 w-32 items-center justify-center rounded-xl bg-base-200 px-3 text-center text-xs font-semibold uppercase tracking-[0.2em] text-base-content/45">
                            No cover
                        </div>
                    }
                </div>

                <div class="grid gap-4 sm:grid-cols-3">
                    <div>
                        <div class="text-sm uppercase tracking-wide text-base-content/60">Author</div>
                        <div class="mt-2 font-semibold">@Model.Author.Name</div>
                    </div>
                    <div>
                        <div class="text-sm uppercase tracking-wide text-base-content/60">ISBN</div>
                        <div class="mt-2 font-semibold">@(string.IsNullOrWhiteSpace(Model.Isbn) ? "Not provided" : Model.Isbn)</div>
                    </div>
                    <div>
                        <div class="text-sm uppercase tracking-wide text-base-content/60">Year</div>
                        <div class="mt-2 font-semibold">@(Model.Year?.ToString() ?? "Unknown")</div>
                    </div>
                </div>
            </div>

            <form asp-action="Delete" class="flex flex-wrap gap-3 pt-2">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-error">Delete book</button>
                <a class="btn btn-ghost" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
            </form>
        </div>
    </div>
</div>
