@model IEnumerable<Bookshelf.Models.Author>

@{
    ViewData["Title"] = "Authors";
    var canManage = User.Identity?.IsAuthenticated == true;
}

<div class="flex flex-col gap-6">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div class="space-y-2">
            <h1 class="text-3xl font-black tracking-tight">Authors</h1>
            <p class="text-base-content/75">Keep a tidy list of the writers behind the books in your collection.</p>
        </div>

        @if (canManage)
        {
            <a class="btn btn-primary" asp-action="Create">Add an author</a>
        }
        else
        {
            <a class="btn btn-outline" asp-controller="Account" asp-action="Login">Log in to manage authors</a>
        }
    </div>

    @if (Model.Any())
    {
        <div class="card bg-base-100 shadow-xl ring-1 ring-base-300/60">
            <div class="card-body p-0">
                <div class="overflow-x-auto">
                    <table class="table table-zebra">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th class="text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var author in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="font-semibold">@author.Name</div>
                                    </td>
                                    <td>
                                        <div class="flex justify-end gap-2">
                                            <a class="btn btn-ghost btn-sm" asp-action="Details" asp-route-id="@author.Id">Details</a>
                                            @if (canManage)
                                            {
                                                <a class="btn btn-ghost btn-sm" asp-action="Edit" asp-route-id="@author.Id">Edit</a>
                                                <a class="btn btn-ghost btn-sm text-error" asp-action="Delete" asp-route-id="@author.Id">Delete</a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="hero rounded-3xl bg-base-100 py-16 shadow-xl ring-1 ring-base-300/60">
            <div class="hero-content text-center">
                <div class="max-w-md space-y-4">
                    <h2 class="text-2xl font-bold">No authors yet</h2>
                    <p class="text-base-content/75">Create an author so you can connect books to the people who wrote them.</p>
                    @if (canManage)
                    {
                        <a class="btn btn-primary" asp-action="Create">Add your first author</a>
                    }
                </div>
            </div>
        </div>
    }
</div>
