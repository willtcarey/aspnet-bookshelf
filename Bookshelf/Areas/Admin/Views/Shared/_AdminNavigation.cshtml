    </a>
    <a asp-area="Admin" asp-controller="Authors" asp-action="Index"
       class="btn btn-ghost justify-start @(currentController == "Authors" ? "btn-active" : "")">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
