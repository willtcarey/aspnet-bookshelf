<div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div class="space-y-2">
        <h1 class="text-3xl font-black tracking-tight @ViewData["PageTitleClass"]">@ViewData["PageTitle"]</h1>
        <p class="text-base-content/75">@ViewData["PageDescription"]</p>
    </div>
    @if (ViewData["PageActionUrl"] is string actionUrl && ViewData["PageActionText"] is string actionText)
    {
        <a class="btn btn-primary" href="@actionUrl">@actionText</a>
    }
</div>
