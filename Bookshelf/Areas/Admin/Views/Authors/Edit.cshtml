@model AdminAuthorFormViewModel

@{
    ViewData["Title"] = "Edit Author";
    ViewData["PageTitle"] = "Edit author";
    ViewData["PageDescription"] = "Update the author details used across your books.";
}

<div class="mx-auto flex max-w-3xl flex-col gap-6">
    <partial name="_PageHeader" />

    <div class="card bg-base-200 shadow-xl ring-1 ring-base-300/60">
        <div class="card-body gap-5">
            <div asp-validation-summary="ModelOnly" class="@(ViewData.ModelState.ErrorCount > 0 ? "alert alert-error" : "hidden") text-sm"></div>

            <form asp-area="Admin" asp-controller="Authors" asp-action="Edit" asp-route-id="@Model.Id" class="space-y-5">
                <input type="hidden" asp-for="Id" />
                <form-text asp-for="Name" />

                <div class="flex flex-wrap gap-3 pt-2">
                    <button type="submit" class="btn btn-primary">Save changes</button>
                    <a class="btn btn-ghost" asp-area="Admin" asp-controller="Authors" asp-action="Index">Back to authors</a>
                </div>
            </form>
        </div>
    </div>
</div>
