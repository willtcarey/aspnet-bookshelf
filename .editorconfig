# Top-level EditorConfig
root = true

###############################################################################
# Default settings for all files
###############################################################################
[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

###############################################################################
# C# files
###############################################################################
[*.cs]

#### Language & code-style rules ####

# Use 'var' when the type is apparent; prefer explicit types elsewhere
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_when_type_is_apparent = true:warning
csharp_style_var_elsewhere = false:warning

# Prefer expression-bodied members where single-line
csharp_style_expression_bodied_methods = when_on_single_line:warning
csharp_style_expression_bodied_constructors = false:warning
csharp_style_expression_bodied_operators = when_on_single_line:warning
csharp_style_expression_bodied_properties = true:warning
csharp_style_expression_bodied_indexers = true:warning
csharp_style_expression_bodied_accessors = true:warning
csharp_style_expression_bodied_lambdas = true:warning
csharp_style_expression_bodied_local_functions = when_on_single_line:warning

# Prefer pattern matching
csharp_style_pattern_matching_over_is_with_cast_check = true:warning
csharp_style_pattern_matching_over_as_with_null_check = true:warning

# Prefer braces
csharp_prefer_braces = true:warning

# Prefer simple using statement
csharp_prefer_simple_using_statement = true:warning

# Namespace declarations
csharp_style_namespace_declarations = file_scoped:warning

# Null-checking preferences
csharp_style_throw_expression = true:warning
csharp_style_conditional_delegate_call = true:warning
dotnet_style_coalesce_expression = true:warning
dotnet_style_null_propagation = true:warning

# 'this.' qualification
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning

# Predefined types over framework types
dotnet_style_predefined_type_for_locals_parameters_members = true:warning
dotnet_style_predefined_type_for_member_access = true:warning

# Modifier preferences
dotnet_style_require_accessibility_modifiers = for_non_interface_members:warning
csharp_preferred_modifier_order = public,private,protected,internal,file,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,required,volatile,async:warning

# Unnecessary code
dotnet_code_quality_unused_parameters = all:warning
csharp_style_unused_value_expression_statement_preference = discard_variable:warning
csharp_style_unused_value_assignment_preference = discard_variable:warning

#### Formatting rules ####

# Newline preferences
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true

# Indentation
csharp_indent_case_contents = true
csharp_indent_switch_labels = true

# Spacing
csharp_space_after_cast = false
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_between_method_declaration_parameter_list_parentheses = false
csharp_space_between_parentheses = false

#### Naming conventions ####

# Interfaces must begin with 'I'
dotnet_naming_rule.interfaces_must_begin_with_i.symbols = interface_symbols
dotnet_naming_rule.interfaces_must_begin_with_i.style = begins_with_i
dotnet_naming_rule.interfaces_must_begin_with_i.severity = warning

dotnet_naming_symbols.interface_symbols.applicable_kinds = interface
dotnet_naming_symbols.interface_symbols.applicable_accessibilities = *

dotnet_naming_style.begins_with_i.required_prefix = I
dotnet_naming_style.begins_with_i.capitalization = pascal_case

# Private fields must begin with '_'
dotnet_naming_rule.private_fields_underscore.symbols = private_field_symbols
dotnet_naming_rule.private_fields_underscore.style = underscore_prefix
dotnet_naming_rule.private_fields_underscore.severity = warning

dotnet_naming_symbols.private_field_symbols.applicable_kinds = field
dotnet_naming_symbols.private_field_symbols.applicable_accessibilities = private, private_protected

dotnet_naming_style.underscore_prefix.required_prefix = _
dotnet_naming_style.underscore_prefix.capitalization = camel_case

# Constants are PascalCase
dotnet_naming_rule.constants_pascal_case.symbols = constant_symbols
dotnet_naming_rule.constants_pascal_case.style = pascal_case_style
dotnet_naming_rule.constants_pascal_case.severity = warning

dotnet_naming_symbols.constant_symbols.applicable_kinds = field
dotnet_naming_symbols.constant_symbols.required_modifiers = const
dotnet_naming_symbols.constant_symbols.applicable_accessibilities = *

dotnet_naming_style.pascal_case_style.capitalization = pascal_case

# All other members are PascalCase
dotnet_naming_rule.members_pascal_case.symbols = all_members
dotnet_naming_rule.members_pascal_case.style = pascal_case_style
dotnet_naming_rule.members_pascal_case.severity = warning

dotnet_naming_symbols.all_members.applicable_kinds = class, struct, enum, property, method, event, delegate, namespace, type_parameter
dotnet_naming_symbols.all_members.applicable_accessibilities = *

# Local variables/parameters are camelCase
dotnet_naming_rule.locals_camel_case.symbols = local_symbols
dotnet_naming_rule.locals_camel_case.style = camel_case_style
dotnet_naming_rule.locals_camel_case.severity = warning

dotnet_naming_symbols.local_symbols.applicable_kinds = parameter, local
dotnet_naming_symbols.local_symbols.applicable_accessibilities = *

dotnet_naming_style.camel_case_style.capitalization = camel_case

###############################################################################
# Analyzer severity overrides
###############################################################################

# --- Rules to DISABLE for this project (noise / not applicable) ---

# CA1002: Do not expose generic lists – real design concern, keep as guidance
dotnet_diagnostic.CA1002.severity = warning

# CA1014: Mark assemblies with CLSCompliant
dotnet_diagnostic.CA1014.severity = warning

# CA1034: Nested types should not be visible
dotnet_diagnostic.CA1034.severity = warning

# CA1062: Validate arguments of public methods
dotnet_diagnostic.CA1062.severity = warning

# CA1305: Specify IFormatProvider – prevents culture-sensitive formatting bugs
dotnet_diagnostic.CA1305.severity = warning

# CA1307: Specify StringComparison for clarity – prevents culture-sensitive string bugs
dotnet_diagnostic.CA1307.severity = warning

# CA1310: Specify StringComparison for correctness – prevents culture-sensitive string bugs
dotnet_diagnostic.CA1310.severity = warning

# CA1515: Consider making public types internal
dotnet_diagnostic.CA1515.severity = warning

# CA1805: Do not initialize unnecessarily
dotnet_diagnostic.CA1805.severity = warning

# CA1848: Use LoggerMessage delegates
dotnet_diagnostic.CA1848.severity = warning

# CA1849: Call async methods when in an async method – catches thread-blocking bugs
dotnet_diagnostic.CA1849.severity = warning

# CA2007: Do not directly await a Task (ConfigureAwait) – not needed in ASP.NET Core
# Microsoft says suppress for ASP.NET Core: https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/quality-rules/ca2007
# Best practices page says don't call ConfigureAwait: https://learn.microsoft.com/en-us/aspnet/core/fundamentals/best-practices#avoid-calling-configureawait
dotnet_diagnostic.CA2007.severity = none

# CA1724: Type names should not match namespaces
dotnet_diagnostic.CA1724.severity = warning

# CA1716: Identifiers should not match keywords
dotnet_diagnostic.CA1716.severity = warning

# CA1054/CA1055/CA1056: URI parameters/return values/properties should not be strings
# ASP.NET Core model binding uses strings, LocalRedirect() takes string
# Rule docs say safe to suppress: https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/quality-rules/ca1054
dotnet_diagnostic.CA1054.severity = none
dotnet_diagnostic.CA1055.severity = none
dotnet_diagnostic.CA1056.severity = none

# CA1303: Do not pass literals as localized parameters
dotnet_diagnostic.CA1303.severity = warning

# CA1812: Avoid uninstantiated internal classes
dotnet_diagnostic.CA1812.severity = warning

# CA1852: Seal internal types
dotnet_diagnostic.CA1852.severity = warning

# CA1308: Normalize strings to uppercase
dotnet_diagnostic.CA1308.severity = warning

# CA1508: Avoid dead conditional code – catches logic issues
dotnet_diagnostic.CA1508.severity = warning

# CA2227: Collection properties should be read only – EF works fine with read-only collections
dotnet_diagnostic.CA2227.severity = warning

# CA1000: Do not declare static members on generic types
dotnet_diagnostic.CA1000.severity = warning

# CA3003: Path injection – analyzer cannot recognize sanitization patterns
# Tried increasing interprocedural analysis depth — still flags. Sanitization in
# NormalizeStoredPath is verified correct. Microsoft says suppress if validated:
# https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/quality-rules/ca3003#when-to-suppress-warnings
dotnet_diagnostic.CA3003.severity = none

# IDE0058: Expression value is never used – can flag real mistakes
dotnet_diagnostic.IDE0058.severity = warning

# IDE0005: Using directive is unnecessary – let the formatter handle this
dotnet_diagnostic.IDE0005.severity = warning

# IDE0046: Use conditional expression for return – style guidance
dotnet_diagnostic.IDE0046.severity = warning

# IDE0045: Use conditional expression for assignment – style guidance
dotnet_diagnostic.IDE0045.severity = warning

# IDE0130: Namespace does not match folder structure
dotnet_diagnostic.IDE0130.severity = warning

# IDE0070: Use System.HashCode – suggestion only
dotnet_diagnostic.IDE0070.severity = warning

###############################################################################
# Generated code – Migrations
###############################################################################
[**/Migrations/*.cs]
generated_code = true
dotnet_analyzer_diagnostic.severity = none
dotnet_diagnostic.IDE0005.severity = none

###############################################################################
# JSON, XML, YAML, etc.
###############################################################################
[*.{json,xml,yml,yaml,csproj,props}]
indent_size = 2

[*.{cshtml,razor}]
indent_size = 4
